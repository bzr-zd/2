304.html"},{"vod_id":2016,"type_id":46,"type_id_1":45,"group_id":0,"vod_name":"森林进化论2025","vod_sub":"","vod_en":"senlinjinhualun2025","vod_status":1,"vod_letter":"S","vod_color":"","vod_tag":"森林进化论2025,森林,竞技,进化论,脑力,残酷性,策略性","vod_class":"大陆综艺","vod_pic":"https://viptulz.com/upload/vod/20250618-1/eef9eb738e0788da7f793b7dc65c1bfc.jpg","vod_pic_thumb":"http://img.test.com/","vod_pic_slide":"http://img.test.com/","vod_pic_screenshot":null,"vod_actor":"","vod_director":"","vod_writer":"","vod_behind":"","vod_blurb":"《森林进化论2025》是一档沉浸式脑力策略博弈竞技综艺。各界优秀青年齐聚于“森林”之中，通过多维竞技体系，在相互制衡的规则之下，将丛林法则的残酷性与策略性推向极致，完成一场场专属于智者间的公平对决。","vod_remarks":"更新至2026-01-02期期","vod_pubdate":"","vod_total":0,"vod_serial":"36","vod_tv":"","vod_weekday":"","vod_area":"大陆","vod_lang":"国语","vod_year":"2025","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":1,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":1894,"vod_hits_day":2,"vod_hits_week":3,"vod_hits_month":3,"vod_duration":"","vod_up":1655,"vod_down":1945,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-01-06 12:18:58","vod_time_add":"2025-09-06 22:09:00","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>《森林进化论2025》是一档沉浸式脑力策略博弈竞技综艺。各界优秀青年齐聚于“森林”之中，通过多维竞技体系，在相互制衡的规则之下，将丛林法则的残酷性与策略性推向极致，完成一场场专属于智者间的公平对决。</p>","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":46,"type_name":"综艺","type_en":"zongyi","type_sort":3,"type_mid":1,"type_pid":45,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭