pe_logo":"","type_pic":"","type_jumpurl":"","childids":"46"},"detail_link":"/voddetail/303972.html"},{"vod_id":318500,"type_id":38,"type_id_1":37,"group_id":0,"vod_name":"被隐匿的真相","vod_sub":"","vod_en":"beiyinnidezhenxiang","vod_status":1,"vod_letter":"B","vod_color":"","vod_tag":"被隐匿的真相,唐堂,布控,高度,裸女案,这起,八公狗舍","vod_class":"悬疑,刑侦,犯罪,国产","vod_pic":"http://image.caiji.cyou/upload/vod/20260206-1/3c53f78a9a68a017190223712a051e89.jpg","vod_pic_thumb":"https://vcover-hz-pic.puui.qpic.cn/vcover_hz_pic/0/mzc00200sp5f6qy1770341994147/0","vod_pic_slide":"https://vcover-hz-pic.puui.qpic.cn/vcover_hz_pic/0/mzc00200sp5f6qy1770341994147/0","vod_pic_screenshot":"","vod_actor":"丁冠森,印小天,黄婷婷,郭品超,王宁,夏志卿,翟宇佳","vod_director":"嵇政","vod_writer":"","vod_behind":"","vod_blurb":"青年刑警唐堂跟随师父参与调查一起十五年前的裸宴案，曾经的主犯白启明再次回到青城市引起了警方的高度重视。在对其布控调查的期间内，发现其牵连出更多的犯罪团伙。在网络平台借以“爱心收留流浪狗”为名的八公狗舍，实际上一直在诓骗民众，以此获取不法利益，同时还和白启明的犯罪行为有着极深的联系；在城内造成重大恶劣影响的偷狗二人组接连不断地引起事端，误食有毒食品的老人小孩激化社会矛盾，而他们背后似乎与“老白”还有着千丝万缕的关联；本地颇具盛名的鸿运餐厅老板王力失手杀人；以及那莫名消失的流浪汉……在这种种谜团的背后，年轻正","vod_remarks":"已完结","vod_pubdate":"2026-02-06","vod_total":12,"vod_serial":"12","vod_tv":"","vod_weekday":"2月6日起，腾讯视频全网独播，会员首周中午12点更新1集，首","vod_area":"内地","vod_lang":"普通话","vod_year":"2026","vod_version":"高清版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":35603,"vod_hits_day":11,"vod_hits_week":12,"vod_hits_month":12,"vod_duration":"","vod_up":716,"vod_down":483,"vod_score":"9.0","vod_score_all":740,"vod_score_num":43,"vod_time":"2026-02-12 12:00:19","vod_time_add":"2026-02-06 20:45:10","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>青年刑警唐堂跟随师父参与调查一起十五年前的裸宴案，曾经的主犯白启明再次回到青城市引起了警方的高度重视。在对其布控调查的期间内，发现其牵连出更多的犯罪团伙。在网络平台借以“爱心收留流浪狗”为名的八公狗舍，实际上一直在诓骗民众，以此获取不法利益，同时还和白启明的犯罪行为有着极深的联系；在城内造成重大恶劣影响的偷狗二人组接连不断地引起事端，误食有毒食品的老人小孩激化社会矛盾，而他们背后似乎与“老白”还有着千丝万缕的关联；本地颇具盛名的鸿运餐厅老板王力失手杀人；以及那莫名消失的流浪汉……在这种种谜团的背后，年轻正义的唐堂逐渐解开了真相，可这时，青梅竹马却遭到绑架，其背后的始作俑者，竟是……</p>","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":38,"type_name":"电视剧","type_en":"guochanju","type_sort":4,"type_mid":1,"type_pid":37,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":37,"type_name":"追剧","type_en":"lianxuju","type_sort":4,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"38"}},"type_1":{"type_id":37,"type_name":"追剧","type_en":"lianxuju","type_sort":4,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"38"},"detail_link":"/voddetail/318500.html"},{"vod_id":314516,"type_id":38,"type_id_1":37,"group_id":0,"vod_name":"轻年","vod_sub":"","vod_en":"qingnian","vod_status":1,"vod_letter":"Q","vod_color":"","vod_tag":"轻年,轻年,浩瀚,兄弟,脑瘤,亲如,突患","vod_class":"生活,都市,剧情,国产","vod_pic":"http://image.caiji.cyou/upload/vod/20251230-1/e814555268edd1bf6887d2c1774445a9.png","vod_pic_thumb":"https://pic0.iqiyipic.com/image/20251229/4a/e6/a_100617986_m_601_m4_480_270.png","vod_pic_slide":"https://pic0.iqiyipic.com/image/20251229/4a/e6/a_100617986_m_601_m4_579_772.png","vod_pic_screenshot":"","vod_actor":"霍建华,田雨,张雪迎,乔振宇,刘端端,隋俊波,张瑶,薛昊婧,祝子杰,温海波,梁丹妮,李勤勤","vod_director":"花箐","vod_writer":"","vod_behind":"","vod_blurb":"上世纪八十年代，马丁和三个亲如兄弟的小伙伴在北京的胡同里一起长大。在高中毕业前夕，一场由马丁引发的变故使他和兄弟三人分崩离析。青春落幕，马丁远走国外，自此销声匿迹。多年以后，已经成为上市公司副总的马丁突患脑瘤，孑然一身的他准备平静地迎接死亡，心底却隐隐有一种羁绊，让他无法割舍。马丁想在离世之前解开宿怨，重拾友情。人到中年的兄弟四人携手创业，每个人的生活都在发生着改变，旧时友情在彼此心中慢慢复苏，马丁也重燃生活的希望。","vod_remarks":"32集全","vod_pubdate":"2025","vod_total":32,"vod_serial":"32","vod_tv":"","vod_weekday":"VIP会员每日18点更新2集","vod_area":"内地","vod_lang":"国语","vod_year":"2025","vod_version":"高清版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":1678,"vod_hits_day":1,"vod_hits_week":3,"vod_hits_month":177,"vod_duration":"","vod_up":1372,"vod_down":1738,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-02-11 16:51:41","vod_time_add":"2025-12-30 18:45:07","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"上世纪八十年代，马丁和三个亲如兄弟的小伙伴在北京的胡同里一起长大。在高中毕业前夕，一场由马丁引发的变故使他和兄弟三人分崩离析。青春落幕，马丁远走国外，自此销声匿迹。多年以后，已经成为上市公司副总的马丁突患脑瘤，孑然一身的他准备平静地迎接死亡，心底却隐隐有一种羁绊，让他无法割舍。马丁想在离世之前解开宿怨，重拾友情。人到中年的兄弟四人携手创业，每个人的生活都在发生着改变，旧时友情在彼此心中慢慢复苏，马丁也重燃生活的希望。","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":38,"type_name":"电视剧","type_en":"guochanju","type_sort":4,"type_mid":1,"type_pid":37,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":37,"type_name":"追剧","type_en":"lianxuju","type_sort":4,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"38"}},"type_1":{"type_id":37,"type_name":"追剧","type_en":"lianxuju","type_sort":4,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"38"},"detail_link":"/voddetail/314516.html"},{"vod_id":218530,"type_id":21,"type_id_1":20,"group_id":0,"vod_name":"热烈","vod_sub":"","vod_en":"relie","vod_status":1,"vod_letter":"R","vod_color":"","vod_tag":"热烈","vod_class":"剧情,喜剧,喜,励志,情,院线,电影（B站）","vod_pic":"http://image.caiji.cyou/upload/vod/20250926-1/fbcd46a494e3573a02c03c135d763df2.jpg","vod_pic_thumb":"https://0img.hitv.com/preview/sp_images/2022/7/26/dianying/463155/17077542/20220726152347965.jpg","vod_pic_slide":"http://img.test.com/","vod_pic_screenshot":"","vod_actor":"黄渤,王一博,宋祖儿,岳云鹏,小沈阳","vod_director":"大鹏","vod_writer":"","vod_behind":"","vod_blurb":"街舞老炮儿丁雷（黄渤 饰），偶遇卖艺少年陈烁（王一博 饰），丁雷忽悠陈烁加入自己经营的舞团。舞团内高手如云，性格各异，与陈烁碰撞出不同的火花，笑料不断。陈烁热烈追梦，期待着上场的机会，却发现丁雷邀请他其实另有目的，而丁雷和陈烁，也都将面对接二连三的沉重打击，他们能否逆风翻盘，回击人生难题？","vod_remarks":"2023年07月28日上映","vod_pubdate":"2022","vod_total":0,"vod_serial":"1","vod_tv":"","vod_weekday":"","vod_area":"","vod_lang":"","vod_year":"2022","vod_version":"高清版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":29076,"vod_hits_day":1,"vod_hits_week":4,"vod_hits_month":3,"vod_duration":"","vod_up":200,"vod_down":445,"vod_score":"8.0","vod_score_all":746,"vod_score_num":13,"vod_time":"2026-02-11 04:46:18","vod_time_add":"2022-07-26 18:28:13","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"5.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>街舞老炮儿丁雷（黄渤 饰），偶遇卖艺少年陈烁（王一博 饰），丁雷忽悠陈烁加入自己经营的舞团。舞团内高手如云，性格各异，与陈烁碰撞出不同的火花，笑料不断。陈烁热烈追梦，期待着上场的机会，却发现丁雷邀请他其实另有目的，而丁雷和陈烁，也都将面对接二连三的沉重打击，他们能否逆风翻盘，回击人生难题？</p>","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":21,"type_name":"电影","type_en":"dongzuopian","type_sort":999,"type_mid":1,"type_pid":20,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":20,"type_name":"电影","type_en":"dianying","type_sort":999,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,家庭,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"21"}},"type_1":{"type_id":20,"type_name":"电影","type_en":"dianying","type_sort":999,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,家庭,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"21"},"detail_link":"/voddetail/218530.html"},{"vod_id":319381,"type_id":21,"type_id_1":20,"group_id":0,"vod_name":"火拼","vod_sub":"","vod_en":"huopin","vod_status":1,"vod_letter":"H","vod_color":"","vod_tag":"火拼","vod_class":"警匪,犯罪,动作,其他","vod_pic":"http://image.caiji.cyou/upload/vod/20260210-1/c3e5a77c5e1909d9607d86da26f2cc05.png","vod_pic_thumb":"https://pic4.iqiyipic.com/image/20260209/ad/d3/v_193179832_m_601_m4_480_270.png","vod_pic_slide":"https://pic4.iqiyipic.com/image/20260209/ad/d3/v_193179832_m_601_m4_1248_702.png","vod_pic_screenshot":"","vod_actor":"方中信,吕良伟,安志杰,张继聪,陈家乐,陈健鸿","vod_director":"吴家伟","vod_writer":"","vod_behind":"","vod_blurb":"香港核心商业地带突发连环抢劫大案，区域内多家珠宝店遭遇悍匪团伙的洗劫！冲锋组长郑志斌一路追击，原来是悍匪头目阮卓龙、阮卓武是多年前另一桩持枪抢劫案的在逃要犯，两人犯案同时还不断向警方挑衅。此外，阮氏兄弟的步步紧逼亦张家和，四人在不断交锋中。","vod_remarks":"","vod_pubdate":"2026","vod_total":1,"vod_serial":"0","vod_tv":"","vod_weekday":"","vod_area":"","vod_lang":"","vod_year":"2026","vod_version":"高清版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":1,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":35452,"vod_hits_day":1,"vod_hits_week":7,"vod_hits_month":1,"vod_duration":"","vod_up":746,"vod_down":494,"vod_score":"7.0","vod_score_all":792,"vod_score_num":31,"vod_time":"2026-02-11 03:58:56","vod_time_add":"2026-02-10 10:30:10","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>香港核心商业地带突发连环抢劫大案，区域内多家珠宝店遭遇悍匪团伙的洗劫！冲锋组长郑志斌一路追击，原来是悍匪头目阮卓龙、阮卓武是多年前另一桩持枪抢劫案的在逃要犯，两人犯案同时还不断向警方挑衅。此外，阮氏兄弟的步步紧逼亦张家和，四人在不断交锋中。</p>","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":21,"type_name":"电影","type_en":"dongzuopian","type_sort":999,"type_mid":1,"type_pid":20,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":20,"type_name":"电影","type_en":"dianying","type_sort":999,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,家庭,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","childids":"21"}},"type_1":{"type_id":20,"type_name":"电影","type_en":"dianying","type_sort":999,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,家庭,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,20