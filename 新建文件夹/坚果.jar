z_pic/0/mzc00200o3jp0vf1766712259259/0","vod_pic_screenshot":"","vod_actor":"赵丽颖,黄晓明,陈明昊,朱媛媛,秦俊杰,耿乐,余皑磊","vod_director":"","vod_writer":"","vod_behind":"","vod_blurb":"平川县为了加快发展，决定设立“月海镇”。李秋萍与郑德诚两名能力及个性突出的干部，秉着“人民城市人民建”的理念，借助改革开放政策和中央一号文件找到了改革的办法，带领成千上万的农民，在没用国家一分钱的情况下，以“集资、合伙”的创举，在滩涂之上建起一座现代化的城市。这是一段从无到有的造城奇迹，更是中国建城史上的一次壮举，几十万农民的命运因此得以改变。李秋萍、郑德诚、解春来、高雪梅等造城者敢想敢干、敢为人先，在阳光灿烂的80年代谱写了华丽的篇章。","vod_remarks":"已完结","vod_pubdate":"2026-01-10","vod_total":40,"vod_serial":"40","vod_tv":"","vod_weekday":"","vod_area":"内地","vod_lang":"国语","vod_year":"2026","vod_version":"高清版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":1,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":1984,"vod_hits_day":2,"vod_hits_week":3,"vod_hits_month":2,"vod_duration":"","vod_up":1935,"vod_down":1604,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-02-24 12:00:29","vod_time_add":"2026-01-10 19:45:13","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"平川县为了加快发展，决定设立“月海镇”。李秋萍与郑德诚两名能力及个性突出的干部，秉着“人民城市人民建”的理念，借助改革开放政策和中央一号文件找到了改革的办法，带领成千上万的农民，在没用国家一分钱的情况下，以“集资、合伙”的创举，在滩涂之上建起一座现代化的城市。这是一段从无到有的造城奇迹，更是中国建城史上的一次壮举，几十万农民的命运因此得以改变。李秋萍、郑德诚、解春来、高雪梅等造城者敢想敢干、敢为人先，在阳光灿烂的80年代谱写了华丽的篇章。","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":38,"type_name":"电视剧","type_en":"guochanju","type_sort":4,"type_mid":1,"type_pid":37,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大