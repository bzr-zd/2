存狠辣前行。","vod_remarks":"更新至10集","vod_pubdate":"2025-12-28","vod_total":26,"vod_serial":"10","vod_tv":"","vod_weekday":"","vod_area":"中国","vod_lang":"","vod_year":"2025","vod_version":"TV版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":665,"vod_hits_day":3,"vod_hits_week":4,"vod_hits_month":17,"vod_duration":"","vod_up":1017,"vod_down":1504,"vod_score":"0.0","vod_score_all":0,"vod_score_num":10,"vod_time":"2026-02-22 12:00:14","vod_time_add":"2025-12-28 20:28:56","vod_trysee":0,"vod_douban_id":36596819,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"天地是万物众生的客舍，光阴是古往今来的过客。残面张开诡异之眼，所视之处生灵涂炭，化为永恒的禁区。残酷末世之下，人如刍狗，少年许青为生存狠辣前行。","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":44,"type_name":"动漫2","type_en":"dongman","type_sort":2,"type_mid":1,"type_pid":43,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":43,"type_name":"动漫","type_en":"dongman","type_sort":2,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜