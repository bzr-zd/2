_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":37,"vod_hits_day":1,"vod_hits_week":4,"vod_hits_month":4,"vod_duration":"","vod_up":1765,"vod_down":1358,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-02-09 23:11:37","vod_time_add":"2026-01-01 11:05:29","vod_trysee":0,"vod_douban_id":36299879,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>动画短片集《中国奇谭2》由9部风格迥异的短片组成：《拜山》《大贵人》《大鸟》《耳中人》《今日动物园》《如何成为三条龙》《三郎》《刑天》《小雪》。12位导演在延续中式想象力的基础上，探索多元题材与风格，挖掘中式内核表达，同时增强了现实关照和寓言属性，在奇幻语境中探寻现实命题，对人的自我身份、家庭关系、社会关系等进行思考和探讨。</p>","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":44,"type_name":"动漫2","type_en":"dongman","type_sort":2,"type_mid":1,"type_pid":43,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":43,"type_name":"动漫","type_en":"dongman","type_sort":2,"type_mid":1,"type_pid":0,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,伦理,戏曲,记录,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春,文艺,微电影,古装,历史,运动,农村,儿童","area":"香港","lang":"","year":"2025","star":"","