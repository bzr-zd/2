老派警察和让人忍俊不禁的圆滑青年。秉承着“破解死亡密码，守护生命尊严”的宗旨，他们各怀绝技、各司其职、屡破奇案，在一桩桩匪夷所思的案件中，见心见性、匡扶正义。天外有天，案中有案，真相渐显，始露人性。","vod_remarks":"30集全","vod_pubdate":"2026-02-03","vod_total":30,"vod_serial":"30","vod_tv":"","vod_weekday":"2月3日腾讯视频全网首播，每日18点更新，会员每日更新2集，","vod_area":"内地","vod_lang":"普通话","vod_year":"2026","vod_version":"高清版","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":7,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":361,"vod_hits_day":1,"vod_hits_week":1,"vod_hits_month":1,"vod_duration":"","vod_up":1919,"vod_down":1838,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-02-23 12:00:07","vod_time_add":"2026-02-03 18:00:17","vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"云汐市公安局刑事技术科是当地要案、奇案的汇聚之地。由队长冷启明领衔，叶谦、司元龙、焦磊、张子芜等人组建而成的调查小组，是一支年轻、专业的刑侦精英团队。他们或是精于推理、善析人性的法场心灵捕手，或是玩转各种侦查仪器的技术控，更有老谋深算，指点迷津的老派警察和让人忍俊不禁的圆滑青年。秉承着“破解死亡密码，守护生命尊严”的宗旨，他们各怀绝技、各司其职、屡破奇案，在一桩桩匪夷所思的案件中，见心见性、匡扶正义。天外有天，案中有案，真相渐显，始露人性。","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type":{"type_id":38,"type_name":"电视剧","type_en":"guochanju","type_sort":4,"type_mid":1,"type_pid":37,"type_status":1,"type_tpl":"type.html","type_tpl_list":"show.html","type_tpl_detail":"detail.html","type_tpl_play":"","type_tpl_down":"","type_key":"","type_des":"","type_title":"","type_union":"","type_extend":{"class":"喜剧,爱情,动作,科幻,战争,谍战,警匪,犯罪,动画,奇幻,剧情,玄幻,情色,家庭,戏曲,记录,西部,脱口秀,歌舞,音乐,魔幻,武侠,冒险,枪战,恐怖,悬疑,传记,惊悚,经典,青春","area":"大陆,香港,台湾,美国,法国,英国,日本,韩国,德国,泰国,印度,意大利,西班牙,加拿大","lang":"","year":"2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010","star":"","director":"","state":"","version":""},"type_logo":"","type_pic":"","type_jumpurl":"","type_1":{"type_id":37,"type_name":"追剧","type_en":"lianxuju",